{
  "expo": {
    "name": "pari-ayiti",
    "slug": "pari-ayiti",
    "version": "1.0.0",
    "scheme": "pariayiti",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.oldephraim.pariayiti",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router"
    ],
    "extra": {
      "oddsApiKey": {},
      "settlementProvider": "mock",
      "enableMockFailures": false,
      "router": {},
      "eas": {
        "projectId": "dd76536e-f636-4bda-a9af-e414435aac69"
      }
    },
    "owner": "oldephraim"
  }
}
